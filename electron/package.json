{
	"name": "electron",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"main": "src/electron/main.js",
	"scripts": {
		"dev:react": "vite",
		"dev:electron": "cross-env NODE_ENV=development electron .",
		"dev": "concurrently \"npm run dev:react\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
		"build": "vite build",
		"prod": "npm run build && cross-env NODE_ENV=production electron .",
		"start": "npm run build && electron .",
		"dist:mac": "npm run build && electron-builder --mac --arm64",
		"dist:win": "npm run build && electron-builder --win --x64",
		"dist:linux": "npm run build && electron-builder --linux --x64",
		"lint": "eslint .",
		"preview": "vite preview"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.3.2",
		"dotenv": "^17.4.2",
		"electron-store": "^11.0.2",
		"googleapis": "^173.0.0",
		"nodemailer": "^9.0.3",
		"qrcode": "^1.5.4",
		"qrcode-terminal": "^0.12.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tailwindcss": "^4.3.2",
		"whatsapp-web.js": "^1.34.7"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"concurrently": "^10.0.3",
		"cross-env": "^10.1.0",
		"electron": "^43.1.0",
		"electron-builder": "^26.15.3",
		"eslint": "^10.6.0",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-refresh": "^0.5.3",
		"globals": "^17.7.0",
		"vite": "^8.1.3",
		"wait-on": "^9.0.10"
	}
}
