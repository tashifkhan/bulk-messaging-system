GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
# Optional: use a downloaded OAuth client JSON instead of the two values above.
# Save it as google-credentials.json in this folder, or set an absolute path here.
# GOOGLE_CREDENTIALS_PATH=/absolute/path/to/client_secret.json
# Optional: only change this if your Google OAuth client uses a different redirect URI.
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback

NODE_ENV=development
